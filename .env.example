# Copy this to .env.local and fill in real values
# WARNING: .env.local contains live secrets — keep it out of git, backups, and screenshots

# Database
DATABASE_URL=postgresql://user:password@host:5432/db

# Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# AI Extraction (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: confidence threshold (0-1). Below this, the pipeline retries with a
# fallback vision model before accepting the result. Default: 0.9
# AI_CONFIDENCE_THRESHOLD=0.9

# Set to "false" to disable the Hy3 validation/reasoning fallback entirely.
# OPENROUTER_VALIDATION_ENABLED=false

# Result caching by perceptual image hash (skips AI for identical re-uploads).
# Set AI_CACHE_ENABLED=false to disable. Cache file path via AI_CACHE_FILE.
# AI_CACHE_ENABLED=true
# AI_CACHE_FILE=./cache/extraction-cache.json

# Structured pipeline logging. Set AI_STRUCTURED_LOGGING=false to silence,
# AI_LOG_LEVEL to debug|info|warn|error (default info).
# AI_STRUCTURED_LOGGING=true
# AI_LOG_LEVEL=info

# Email verification (Resend)
RESEND_API_KEY=re_your-key-here
RESEND_FROM=noreply@yourdomain.com

# File storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bot protection (Cloudflare Turnstile)
# Get keys: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAA...

# Security contact (for /.well-known/security.txt)
SECURITY_CONTACT=https://github.com/sairwhat/project-schedly/security/advisories/new
