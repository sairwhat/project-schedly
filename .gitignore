# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
src/generated/

# runtime uploads
/public/uploads/

# docker
docker-compose.override.yml

# capacitor / android
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
android/capacitor.settings.gradle
android/capacitor.build.gradle
android/app/capacitor.build.gradle
# signing keys (never commit — provided via CI secrets)
*.keystore
*.jks

# project specific
CLAUDE.md

# benchmark generated artifacts
benchmark/fixtures/
benchmark/report.json
benchmark/report.md
